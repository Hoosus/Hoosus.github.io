---
import { research } from "../data/research";
---

<section id="research">
  <h2>Research</h2>
  <div class="grid">
    {research.map((item) => (
      <div class="card">
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }

  .card {
    padding: 20px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    transition: border-color 0.2s;
  }

  .card:hover {
    border-color: var(--color-accent);
  }

  h3 {
    font-size: 1.1rem;
    margin-bottom: 8px;
  }

  p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }
</style>
