---
import { news } from "../data/news";
---

<section id="news">
  <h2>News</h2>
  <ul>
    {news.map((item) => (
      <li>
        <span class="date">{item.date}</span>
        <span class="content">{item.content}</span>
      </li>
    ))}
  </ul>
</section>

<style>
  ul {
    list-style: none;
    padding: 0;
  }

  li {
    padding: 10px 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    gap: 16px;
  }

  li:last-child {
    border-bottom: none;
  }

  .date {
    color: var(--color-text-light);
    font-size: 0.9rem;
    white-space: nowrap;
    min-width: 60px;
  }

  .content {
    font-size: 0.95rem;
  }
</style>
